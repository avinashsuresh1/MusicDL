{
  "name": "musicdl",
  "version": "0.1.0",
  "description": "A YAML-based music definition language core library",
  "private": true,
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.5.0",
    "vite": "^7.3.6",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "esbuild-wasm": "0.28.1",
    "js-yaml": "^5.2.1"
  },
  "overrides": {
    "vite": {
      "esbuild": "npm:esbuild-wasm@0.28.1"
    },
    "vitest": {
      "esbuild": "npm:esbuild-wasm@0.28.1"
    }
  }
}
